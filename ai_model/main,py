import os
import pickle
from flask import Flask, request, jsonify
from flask_cors import CORS
from dotenv import load_dotenv
from pymongo import MongoClient

load_dotenv()
app = Flask(__name__)
CORS(app)

# 1. Load your AI Brains
with open('health_risk_model.pkl', 'rb') as f:
    risk_model = pickle.load(f)

# 2. Database Connection
client = MongoClient(os.getenv("MONGO_URI"))
db = client['Aetherion_26']
collection = db['Patients']

@app.route('/predict/<user_id>', methods=['POST'])
def predict_and_save(user_id):
    # Get user data from Mongo
    user = collection.find_one({"user_id": user_id})
    if not user:
        return jsonify({"error": "User not found"}), 404

    # Get latest vitals (Logic for your model)
    latest_vitals = user['health_logs'][-1]['vitals']
    features = [[latest_vitals['spo2'], latest_vitals['bpm']]] # Match your model_columns.pkl
    
    # 3. Use your .pkl model!
    prediction = risk_model.predict(features)[0]
    
    # 4. Save analysis back to DB
    analysis = {
        "status": str(prediction),
        "timestamp": "2026-03-12" # Example timestamp
    }
    collection.update_one({"user_id": user_id}, {"$push": {"analysis_history": analysis}})

    return jsonify({"user": user['name'], "risk": str(prediction)})

if __name__ == "__main__":
    app.run(host='0.0.0.0', port=5000)